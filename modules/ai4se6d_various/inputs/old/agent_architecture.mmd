    style PROC_TOOLS fill:#0f3460,stroke:#7AB8F5,stroke-width:1px,color:#fafafa
    style WEB_TOOLS fill:#0f3460,stroke:#7AB8F5,stroke-width:1px,color:#fafafa
    style CODE_TOOLS fill:#0f3460,stroke:#7AB8F5,stroke-width:1px,color:#fafafa
    style EXT_APIS fill:#161b22,stroke:#555,stroke-width:1px,color:#fafafa
    style SA_A fill:#0f3460,stroke:#2EC4B6,stroke-width:1px,color:#fafafa
    style SA_B fill:#0f3460,stroke:#2EC4B6,stroke-width:1px,color:#fafafa
